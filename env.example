OPENAI_API_KEY=
# Required for live Forge coaching via /api/coach (Responses API).
# If unset, Forge falls back to a local mock response.
# If set but invalid, Continue shows an OpenAI auth error.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
GITHUB_TOKEN=
GITHUB_REPO=dlatevilawson/talkforge
# Optional privileged key for admin migrations only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
