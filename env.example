OPENAI_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
GITHUB_TOKEN=
GITHUB_REPO=dlatevilawson/talkforge
# Optional privileged key for admin migrations only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# GitHub Sign-In (Supabase Auth)
# 1. Supabase Dashboard → Authentication → Providers → enable GitHub
# 2. Create a GitHub OAuth App (Settings → Developer settings → OAuth Apps)
#    Homepage URL: your app origin (e.g. http://localhost:3000)
#    Authorization callback URL: https://<project-ref>.supabase.co/auth/v1/callback
# 3. Paste Client ID + Secret into the Supabase GitHub provider settings
# 4. Supabase Dashboard → Authentication → URL Configuration → add redirect URL:
#    http://localhost:3000/auth/callback
#    https://<your-production-domain>/auth/callback
